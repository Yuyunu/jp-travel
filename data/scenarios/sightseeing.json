{
  "id": "sightseeing",
  "name_zh": "觀光景點",
  "name_ja": "観光地",
  "emoji": "📸",
  "dialogues": [
    {
      "id": "sight-ticket",
      "title_zh": "買票",
      "title_ja": "チケットを買う",
      "turns": [
        { "role": "A", "ja": "すみません、{大人|おとな}{二枚|にまい}と{子供|こども}{一枚|いちまい}ください。", "zh": "不好意思，大人 2 張、小孩 1 張。" },
        { "role": "B", "ja": "{合計|ごうけい}{2400円|にせんよんひゃくえん}です。", "zh": "總計 2,400 日圓。" },
        { "role": "A", "ja": "{学生|がくせい}{割引|わりびき}はありますか。", "zh": "有學生優惠嗎？" },
        { "role": "B", "ja": "{学生証|がくせいしょう}があれば{200円|にひゃくえん}{引|び}きになります。", "zh": "有學生證的話折 200 日圓。" },
        { "role": "A", "ja": "{何時|なんじ}まで{入|はい}れますか。", "zh": "幾點之前可以進去？" },
        { "role": "B", "ja": "{最終|さいしゅう}{入場|にゅうじょう}は{16時半|じゅうろくじはん}です。", "zh": "最後入場是 16:30。" }
      ]
    },
    {
      "id": "sight-locker",
      "title_zh": "寄物 + 拍照",
      "title_ja": "コインロッカー・写真",
      "turns": [
        { "role": "A", "ja": "コインロッカーはどこですか。", "zh": "投幣置物櫃在哪裡？" },
        { "role": "B", "ja": "{入口|いりぐち}の{右側|みぎがわ}にございます。", "zh": "在入口的右邊。" },
        { "role": "A", "ja": "{大|おお}きい{荷物|にもつ}も{入|はい}りますか。", "zh": "大行李也放得進去嗎？" },
        { "role": "B", "ja": "{大型|おおがた}ロッカーは{500円|ごひゃくえん}です。", "zh": "大型置物櫃 500 日圓。" },
        { "role": "A", "ja": "すみません、{写真|しゃしん}を{撮|と}ってもいいですか。", "zh": "不好意思，可以拍照嗎？" },
        { "role": "B", "ja": "はい、フラッシュは{使|つか}わないでください。", "zh": "可以，請不要用閃光燈。" },
        { "role": "A", "ja": "{一緒|いっしょ}に{撮|と}っていただけますか。", "zh": "可以幫我們合照嗎？" },
        { "role": "B", "ja": "もちろんです。", "zh": "當然可以。" }
      ]
    },
    {
      "id": "sight-toilet",
      "title_zh": "問廁所 / 觀光巴士",
      "title_ja": "トイレ・観光バス",
      "turns": [
        { "role": "A", "ja": "すみません、お{手洗|てあら}いはどこですか。", "zh": "不好意思，洗手間在哪裡？" },
        { "role": "B", "ja": "あちらの{階段|かいだん}を{下|お}りた{所|ところ}にございます。", "zh": "在那邊樓梯下去的地方。" },
        { "role": "A", "ja": "{観光|かんこう}バスは{何時|なんじ}{発|はつ}ですか。", "zh": "觀光巴士幾點發車？" },
        { "role": "B", "ja": "{次|つぎ}は{15時|じゅうごじ}{発|はつ}、{所要|しょよう}{2時間|にじかん}です。", "zh": "下一班 15 點發車，全程 2 小時。" },
        { "role": "A", "ja": "{中国語|ちゅうごくご}の{案内|あんない}はありますか。", "zh": "有中文導覽嗎？" },
        { "role": "B", "ja": "{音声|おんせい}ガイドがございます。", "zh": "有語音導覽。" }
      ]
    }
  ],
