{
  "id": "hotel",
  "name_zh": "飯店",
  "name_ja": "ホテル",
  "emoji": "🏨",
  "dialogues": [
    {
      "id": "hotel-checkin",
      "title_zh": "Check-in",
      "title_ja": "チェックイン",
      "turns": [
        {
          "role": "B",
          "ja": "いらっしゃいませ。チェックインですか。",
          "zh": "歡迎光臨，要 check-in 嗎？"
        },
        {
          "role": "A",
          "ja": "はい、{田中|たなか}で{予約|よやく}しました。",
          "zh": "是的，我用田中的名字訂的。"
        },
        {
          "role": "B",
          "ja": "お{名前|なまえ}を{確認|かくにん}いたします。パスポートをお{願|ねが}いします。",
          "zh": "我幫您確認姓名，麻煩給我護照。"
        },
        {
          "role": "A",
          "ja": "はい、どうぞ。",
          "zh": "好，請。"
        },
        {
          "role": "B",
          "ja": "{二|に}{泊|はく}で{禁|きん}{煙|えん}{室|しつ}、ツインでよろしいですね。",
          "zh": "兩晚禁菸雙床房，這樣對嗎？"
        },
        {
          "role": "A",
          "ja": "はい、{合|あ}っています。",
          "zh": "對，沒錯。"
        },
        {
          "role": "B",
          "ja": "お{部屋|へや}は{805号室|はちまるごごうしつ}です。{鍵|かぎ}はこちらです。",
          "zh": "您的房間是 805 號房，這是鑰匙。"
        },
        {
          "role": "A",
          "ja": "{朝|ちょう}{食|しょく}は{何時|なんじ}からですか。",
          "zh": "早餐幾點開始？"
        },
        {
          "role": "B",
          "ja": "{七時|しちじ}から{十時|じゅうじ}までです。レストランは{二階|にかい}です。",
          "zh": "七點到十點，餐廳在二樓。"
        },
        {
          "role": "A",
          "ja": "ありがとうございます。",
          "zh": "謝謝。"
        }
      ]
    },
    {
      "id": "hotel-complaint",
      "title_zh": "要枕頭 / 冷氣壞掉",
      "title_ja": "枕の追加・エアコンの故障",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{枕|まくら}をもう{一|ひと}つください。",
          "zh": "不好意思，請再給我一個枕頭。"
        },
        {
          "role": "B",
          "ja": "かしこまりました。すぐにお{持|も}ちします。",
          "zh": "好的，馬上送過去。"
        },
        {
          "role": "A",
          "ja": "あと、エアコンが{効|き}きません。",
          "zh": "還有，冷氣不冷。"
        },
        {
          "role": "B",
          "ja": "{申|もう}し{訳|わけ}ございません。すぐ{確認|かくにん}いたします。",
          "zh": "非常抱歉，我馬上確認。"
        },
        {
          "role": "A",
          "ja": "{部屋|へや}を{変|か}えてもらえますか。",
          "zh": "可以幫我換房間嗎？"
        },
        {
          "role": "B",
          "ja": "{少々|しょうしょう}お{待|ま}ちください。{空|あ}いている{部屋|へや}を{調|しら}べます。",
          "zh": "請稍等，我查一下有沒有空房。"
        },
        {
          "role": "A",
          "ja": "お{願|ねが}いします。",
          "zh": "麻煩你了。"
        }
      ]
    },
    {
      "id": "hotel-checkout",
      "title_zh": "Check-out + 寄物",
      "title_ja": "チェックアウト・荷物預け",
      "turns": [
        {
          "role": "A",
          "ja": "チェックアウトお{願|ねが}いします。",
          "zh": "我要 check-out。"
        },
        {
          "role": "B",
          "ja": "お{部屋|へや}の{鍵|かぎ}をお{預|あず}かりします。",
          "zh": "請給我房間鑰匙。"
        },
        {
          "role": "A",
          "ja": "{荷|に}{物|もつ}を{夕方|ゆうがた}まで{預|あず}かってもらえますか。",
          "zh": "可以幫我寄放行李到傍晚嗎？"
        },
        {
          "role": "B",
          "ja": "はい、こちらの{番号札|ばんごうふだ}をお{持|も}ちください。",
          "zh": "可以，請拿好這張號碼牌。"
        },
        {
          "role": "A",
          "ja": "{領収書|りょうしゅうしょ}をお{願|ねが}いします。",
          "zh": "請給我收據。"
        },
        {
          "role": "B",
          "ja": "かしこまりました。{少々|しょうしょう}お{待|ま}ちください。",
          "zh": "好的，請稍等。"
        }
      ]
    }
  ],
