{
  "id": "flight",
  "name_zh": "飛機上",
  "name_ja": "機内",
  "emoji": "💺",
  "dialogues": [
    {
      "id": "flight-service",
      "title_zh": "要毛毯／飲料",
      "title_ja": "ブランケット・飲み物",
      "turns": [
        { "role": "A", "ja": "すみません、{毛布|もうふ}をください。", "zh": "不好意思，請給我一條毛毯。" },
        { "role": "B", "ja": "はい、{少々|しょうしょう}お{待|ま}ちください。", "zh": "好的，請稍等。" },
        { "role": "A", "ja": "それと、お{水|みず}もお{願|ねが}いします。", "zh": "還有，也請給我水。" },
        { "role": "B", "ja": "{冷|つめ}たいお{水|みず}でよろしいですか。", "zh": "冰水可以嗎？" },
        { "role": "A", "ja": "はい、お{願|ねが}いします。", "zh": "好，麻煩你。" },
        { "role": "B", "ja": "お{飲|の}み{物|もの}は{何|なに}になさいますか。", "zh": "請問飲料要點什麼？" },
        { "role": "A", "ja": "りんごジュースをください。", "zh": "請給我蘋果汁。" }
      ]
    },
    {
      "id": "flight-meal",
      "title_zh": "機內餐",
      "title_ja": "機内食",
      "turns": [
        { "role": "B", "ja": "{機内食|きないしょく}は{牛肉|ぎゅうにく}か{鶏肉|とりにく}、どちらになさいますか。", "zh": "機內餐是牛肉或雞肉，您選哪一個？" },
        { "role": "A", "ja": "{鶏肉|とりにく}でお{願|ねが}いします。", "zh": "麻煩雞肉。" },
        { "role": "B", "ja": "パンとライスはどちらに。", "zh": "麵包跟飯選哪個？" },
        { "role": "A", "ja": "ライスをください。", "zh": "我要飯。" },
        { "role": "A", "ja": "すみません、トレイを{下|さ}げてください。", "zh": "不好意思，請收一下托盤。" },
        { "role": "B", "ja": "かしこまりました。", "zh": "好的。" },
        { "role": "A", "ja": "{気分|きぶん}が{悪|わる}いです。", "zh": "我有點不舒服。" },
        { "role": "B", "ja": "エチケット{袋|ぶくろ}はこちらにございます。", "zh": "嘔吐袋在這裡。" }
      ]
    },
    {
      "id": "flight-form",
      "title_zh": "問入境表格",
      "title_ja": "入国カードについて",
      "turns": [
        { "role": "A", "ja": "すみません、{入国|にゅうこく}カードを{一枚|いちまい}ください。", "zh": "不好意思，請給我一張入境卡。" },
        { "role": "B", "ja": "はい、ペンも{要|い}りますか。", "zh": "好的，需要筆嗎？" },
        { "role": "A", "ja": "はい、お{願|ねが}いします。", "zh": "好，麻煩你。" },
        { "role": "A", "ja": "{書|か}き{方|かた}が{分|わ}かりません。", "zh": "我不知道怎麼填。" },
        { "role": "B", "ja": "{見本|みほん}をお{持|も}ちします。", "zh": "我幫您拿範本來。" },
        { "role": "A", "ja": "ありがとうございます。", "zh": "謝謝。" }
      ]
    }
  ],
