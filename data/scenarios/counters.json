{
  "id": "counters",
  "name_zh": "單位詞",
  "name_ja": "助数詞",
  "emoji": "🔢",
  "dialogues": [
    {
      "id": "cnt-cafe",
      "title_zh": "咖啡店點兩杯",
      "title_ja": "カフェで2杯",
      "turns": [
        {
          "role": "A",
          "ja": "コーヒーを{二杯|にはい}ください。",
          "zh": "請給我兩杯咖啡。"
        },
        {
          "role": "B",
          "ja": "ホットですか、アイスですか。",
          "zh": "要熱的還是冰的？"
        },
        {
          "role": "A",
          "ja": "{一杯|いっぱい}はホット、もう{一杯|いっぱい}はアイスでお{願|ねが}いします。",
          "zh": "一杯熱、一杯冰，麻煩你。"
        },
        {
          "role": "B",
          "ja": "ケーキも{一個|いっこ}いかがですか。",
          "zh": "要不要也來一個蛋糕？"
        },
        {
          "role": "A",
          "ja": "じゃ、チョコケーキを{一個|いっこ}ください。",
          "zh": "那給我一個巧克力蛋糕。"
        }
      ]
    },
    {
      "id": "cnt-ramen",
      "title_zh": "拉麵店點餐",
      "title_ja": "ラーメンを注文",
      "turns": [
        {
          "role": "A",
          "ja": "{醤油|しょうゆ}ラーメンを{一杯|いっぱい}と{餃子|ぎょうざ}を{一皿|ひとさら}ください。",
          "zh": "醬油拉麵一碗、餃子一盤。"
        },
        {
          "role": "B",
          "ja": "お{飲|の}み{物|もの}は？",
          "zh": "飲料呢？"
        },
        {
          "role": "A",
          "ja": "ビールを{一本|いっぽん}お{願|ねが}いします。",
          "zh": "啤酒一瓶，麻煩你。"
        },
        {
          "role": "B",
          "ja": "かしこまりました。",
          "zh": "好的。"
        },
        {
          "role": "A",
          "ja": "あ、お{水|みず}も{一杯|いっぱい}いただけますか。",
          "zh": "啊，可以再給我一杯水嗎？"
        }
      ]
    },
    {
      "id": "cnt-souvenir",
      "title_zh": "買伴手禮",
      "title_ja": "お土産を買う",
      "turns": [
        {
          "role": "A",
          "ja": "このお{菓子|かし}を{二箱|ふたはこ}ください。",
          "zh": "這個點心請給我兩盒。"
        },
        {
          "role": "B",
          "ja": "{包装|ほうそう}いたしますか。",
          "zh": "需要包裝嗎？"
        },
        {
          "role": "A",
          "ja": "はい、{袋|ふくろ}も{二|ふた}つお{願|ねが}いします。",
          "zh": "好，袋子也麻煩給我兩個。"
        },
        {
          "role": "B",
          "ja": "プラモデルを{一箱|ひとはこ}と、Tシャツを{二枚|にまい}で{合計|ごうけい}{6800円|ろくせんはっぴゃくえん}です。",
          "zh": "模型一盒、T 恤兩件，合計 6800 日圓。"
        },
        {
          "role": "A",
          "ja": "カードでお{願|ねが}いします。",
          "zh": "刷卡，麻煩你。"
        }
      ]
    }
  ],
