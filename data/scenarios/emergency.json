  "dialogues": [
    {
      "id": "emg-lost",
      "title_zh": "迷路 / 問路",
      "title_ja": "道に迷う・道を聞く",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{道|みち}に{迷|まよ}いました。",
          "zh": "不好意思，我迷路了。"
        },
        {
          "role": "A",
          "ja": "ここはどこですか。",
          "zh": "這裡是哪裡？"
        },
        {
          "role": "B",
          "ja": "{地|ち}{図|ず}を{見|み}せていただけますか。",
          "zh": "可以給我看地圖嗎？"
        },
        {
          "role": "A",
          "ja": "ホテルに{戻|もど}りたいです。",
          "zh": "我想回飯店。"
        },
        {
          "role": "B",
          "ja": "ホテルの{名前|なまえ}は。",
          "zh": "飯店叫什麼？"
        },
        {
          "role": "A",
          "ja": "{新|しん}{宿|じゅく}プリンスホテルです。",
          "zh": "新宿王子飯店。"
        },
        {
          "role": "B",
          "ja": "{次|つぎ}の{角|かど}を{右|みぎ}に{曲|ま}がって、{真|ま}っすぐです。",
          "zh": "下個轉角右轉，然後直走。"
        },
        {
          "role": "A",
          "ja": "ありがとうございます。{助|たす}かりました。",
          "zh": "謝謝，幫了大忙。"
        }
      ]
    },
    {
      "id": "emg-sick",
      "title_zh": "生病 / 看醫生",
      "title_ja": "体調不良・病院",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{気|き}{分|ぶん}が{悪|わる}いです。",
          "zh": "不好意思，我不舒服。"
        },
        {
          "role": "B",
          "ja": "どうされましたか。",
          "zh": "怎麼了？"
        },
        {
          "role": "A",
          "ja": "{頭|あたま}が{痛|いた}いです。{熱|ねつ}もあります。",
          "zh": "頭痛，也有發燒。"
        },
        {
          "role": "B",
          "ja": "{病院|びょういん}にお{連|つ}れしましょうか。",
          "zh": "我帶您去醫院好嗎？"
        },
        {
          "role": "A",
          "ja": "お{願|ねが}いします。",
          "zh": "麻煩你了。"
        },
        {
          "role": "A",
          "ja": "{薬|くすり}にアレルギーがあります。",
          "zh": "我對藥有過敏。"
        },
        {
          "role": "B",
          "ja": "{何|なに}のアレルギーですか。",
          "zh": "對什麼過敏？"
        },
        {
          "role": "A",
          "ja": "ペニシリンです。",
          "zh": "盤尼西林。"
        }
      ]
    },
    {
      "id": "emg-lost-item",
      "title_zh": "丟東西 / 找警察",
      "title_ja": "落とし物・交番",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{財|さい}{布|ふ}を{落|お}としました。",
          "zh": "不好意思，我錢包掉了。"
        },
        {
          "role": "B",
          "ja": "どこで{落|お}としましたか。",
          "zh": "在哪裡掉的？"
        },
        {
          "role": "A",
          "ja": "{多分|たぶん}{電車|でんしゃ}の{中|なか}です。",
          "zh": "大概在電車裡。"
        },
        {
          "role": "B",
          "ja": "{交番|こうばん}で{紛失届|ふんしつとどけ}を{出|だ}してください。",
          "zh": "請去派出所報失。"
        },
        {
          "role": "A",
          "ja": "パスポートも{失|な}くしました。",
          "zh": "護照也丟了。"
        },
        {
          "role": "B",
          "ja": "{大使館|たいしかん}にも{連絡|れんらく}が{必要|ひつよう}です。",
          "zh": "也要聯絡大使館。"
        },
        {
          "role": "A",
          "ja": "{中|ちゅう}{国|ごく}{語|ご}が{話|はな}せる{方|かた}はいますか。",
          "zh": "有會說中文的人嗎？"
        },
        {
          "role": "B",
          "ja": "{通|つう}{訳|やく}を{呼|よ}びますので、{少々|しょうしょう}お{待|ま}ちください。",
          "zh": "我幫您叫翻譯，請稍等。"
        }
      ]
    }
  ],
