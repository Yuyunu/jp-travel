{
  "id": "izakaya",
  "name_zh": "居酒屋",
  "name_ja": "居酒屋",
  "emoji": "🏮",
  "dialogues": [
    {
      "id": "izakaya-seat",
      "title_zh": "入座 + 第一杯",
      "title_ja": "席案内・最初の一杯",
      "turns": [
        {
          "role": "B",
          "ja": "いらっしゃいませ。{何名様|なんめいさま}ですか。",
          "zh": "歡迎光臨，幾位？"
        },
        {
          "role": "A",
          "ja": "{二|ふた}{人|り}です。",
          "zh": "兩個人。"
        },
        {
          "role": "B",
          "ja": "カウンターでよろしいですか。",
          "zh": "吧檯可以嗎？"
        },
        {
          "role": "A",
          "ja": "テーブルがあれば、テーブルでお{願|ねが}いします。",
          "zh": "如果有桌位，麻煩給我桌位。"
        },
        {
          "role": "B",
          "ja": "こちらへどうぞ。お{飲|の}み{物|もの}は{先|さき}にお{決|き}まりですか。",
          "zh": "這邊請。飲料先決定好了嗎？"
        },
        {
          "role": "A",
          "ja": "{生|なま}ビールを{二|ふた}つください。",
          "zh": "請給我兩杯生啤。"
        },
        {
          "role": "B",
          "ja": "{中|ちゅう}ジョッキでよろしいですか。",
          "zh": "中杯可以嗎？"
        },
        {
          "role": "A",
          "ja": "はい、{中|ちゅう}でお{願|ねが}いします。",
          "zh": "好，中杯，麻煩你。"
        },
        {
          "role": "B",
          "ja": "{先|さき}にお{通|とお}しをお{持|も}ちします。",
          "zh": "我先送上小菜。"
        }
      ]
    },
    {
      "id": "izakaya-order",
      "title_zh": "點菜（刺身／串燒）",
      "title_ja": "刺身・串焼きの注文",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{注文|ちゅうもん}お{願|ねが}いします。",
          "zh": "不好意思，我要點菜。"
        },
        {
          "role": "B",
          "ja": "はい、どうぞ。",
          "zh": "好的，請說。"
        },
        {
          "role": "A",
          "ja": "{枝|えだ}{豆|まめ}と{唐|から}{揚|あ}げをください。",
          "zh": "請給我毛豆跟炸雞塊。"
        },
        {
          "role": "A",
          "ja": "{刺|さし}{身|み}の{盛|も}り{合|あ}わせもお{願|ねが}いします。",
          "zh": "綜合生魚片也請給我。"
        },
        {
          "role": "B",
          "ja": "{何人前|なんにんまえ}にされますか。",
          "zh": "要幾人份？"
        },
        {
          "role": "A",
          "ja": "{二人前|ににんまえ}でお{願|ねが}いします。",
          "zh": "兩人份，麻煩你。"
        },
        {
          "role": "A",
          "ja": "{焼|や}き{鳥|とり}は、{もも|もも}を{二|に}{本|ほん}、ねぎまを{二|に}{本|ほん}。タレでお{願|ねが}いします。",
          "zh": "烤雞串：雞腿肉 2 串，蔥肉 2 串，沾醬，麻煩你。"
        },
        {
          "role": "B",
          "ja": "かしこまりました。{他|ほか}にご{注文|ちゅうもん}は。",
          "zh": "好的，還有要點什麼嗎？"
        },
        {
          "role": "A",
          "ja": "{以上|いじょう}でお{願|ねが}いします。",
          "zh": "就這樣，麻煩你。"
        }
      ]
    },
    {
      "id": "izakaya-checkout",
      "title_zh": "再來一杯 + 結帳",
      "title_ja": "おかわり・お会計",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、ハイボールをもう{一|いっ}{杯|ぱい}ください。",
          "zh": "不好意思，再來一杯 highball。"
        },
        {
          "role": "B",
          "ja": "かしこまりました。",
          "zh": "好的。"
        },
        {
          "role": "A",
          "ja": "お{会計|かいけい}お{願|ねが}いします。",
          "zh": "麻煩結帳。"
        },
        {
          "role": "B",
          "ja": "{別々|べつべつ}になさいますか。",
          "zh": "要分開算嗎？"
        },
        {
          "role": "A",
          "ja": "{一|いっ}{緒|しょ}で{結構|けっこう}です。",
          "zh": "一起就好。"
        },
        {
          "role": "B",
          "ja": "{合計|ごうけい}{六千|ろくせん}{八百|はっぴゃく}{円|えん}です。",
          "zh": "總計 6,800 日圓。"
        },
        {
          "role": "A",
          "ja": "カードでいいですか。",
          "zh": "可以刷卡嗎？"
        },
        {
          "role": "B",
          "ja": "{現|げん}{金|きん}のみでございます。",
          "zh": "只收現金。"
        }
      ]
    }
  ],
