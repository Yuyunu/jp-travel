{
  "id": "airport",
  "name_zh": "機場",
  "name_ja": "空港",
  "emoji": "✈️",
  "dialogues": [
    {
      "id": "airport-immigration",
      "title_zh": "入境審查",
      "title_ja": "入国審査",
      "turns": [
        { "role": "B", "ja": "パスポートをお{願|ねが}いします。", "zh": "請給我護照。" },
        { "role": "A", "ja": "はい、どうぞ。", "zh": "好的，請。" },
        { "role": "B", "ja": "ご{旅行|りょこう}ですか、お{仕事|しごと}ですか。", "zh": "是來旅行的還是工作的？" },
        { "role": "A", "ja": "{観光|かんこう}です。", "zh": "觀光。" },
        { "role": "B", "ja": "{何日間|なんにちかん}{滞在|たいざい}しますか。", "zh": "預計停留幾天？" },
        { "role": "A", "ja": "{五日間|いつかかん}です。", "zh": "五天。" },
        { "role": "B", "ja": "どこに{泊|と}まりますか。", "zh": "住在哪裡？" },
        { "role": "A", "ja": "{新宿|しんじゅく}のホテルです。", "zh": "新宿的飯店。" },
        { "role": "B", "ja": "ありがとうございます。はい、どうぞ。", "zh": "謝謝，請過。" }
      ]
    },
    {
      "id": "airport-baggage",
      "title_zh": "行李沒出來",
      "title_ja": "荷物が出てこない",
      "turns": [
        { "role": "A", "ja": "すみません、{荷物|にもつ}が{出|で}てきません。", "zh": "不好意思，我的行李沒出來。" },
        { "role": "B", "ja": "{搭乗券|とうじょうけん}を{見|み}せてください。", "zh": "請給我看您的登機證。" },
        { "role": "A", "ja": "はい、これです。", "zh": "好，這個。" },
        { "role": "B", "ja": "お{名前|なまえ}と{便名|びんめい}を{確認|かくにん}させてください。", "zh": "麻煩確認您的姓名跟班機號碼。" },
        { "role": "A", "ja": "{田中|たなか}です。JL〇〇{便|びん}です。", "zh": "我姓田中，JL○○班機。" },
        { "role": "B", "ja": "{少々|しょうしょう}お{待|ま}ちください。{調|しら}べます。", "zh": "請稍等一下，我幫您查。" },
        { "role": "A", "ja": "ホテルに{届|とど}けてもらえますか。", "zh": "可以幫我送到飯店嗎？" },
        { "role": "B", "ja": "はい、ご{住所|じゅうしょ}をお{書|か}きください。", "zh": "好的，請您填寫地址。" }
      ]
    },
    {
      "id": "airport-bus",
      "title_zh": "問利木津巴士",
      "title_ja": "リムジンバスを聞く",
      "turns": [
        { "role": "A", "ja": "すみません、{新宿|しんじゅく}{行|ゆ}きのバスはどこですか。", "zh": "不好意思，往新宿的巴士在哪裡？" },
        { "role": "B", "ja": "リムジンバスでしたら、{3番|さんばん}{乗|の}り{場|ば}です。", "zh": "利木津巴士的話，是 3 號乘車處。" },
        { "role": "A", "ja": "{切符|きっぷ}はどこで{買|か}えますか。", "zh": "車票在哪裡買？" },
        { "role": "B", "ja": "あちらの{自動販売機|じどうはんばいき}で{買|か}えます。", "zh": "在那邊的自動售票機可以買。" },
        { "role": "A", "ja": "{次|つぎ}のバスは{何時|なんじ}ですか。", "zh": "下一班幾點？" },
        { "role": "B", "ja": "{次|つぎ}は{10時20分|じゅうじにじゅっぷん}{発|はつ}です。", "zh": "下一班 10 點 20 分發車。" },
        { "role": "A", "ja": "ありがとうございます。", "zh": "謝謝。" }
      ]
    }
  ],
