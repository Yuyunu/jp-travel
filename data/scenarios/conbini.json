    {
      "id": "conbini-checkout",
      "title_zh": "便利店結帳",
      "title_ja": "コンビニのレジ",
      "turns": [
        { "role": "B", "ja": "いらっしゃいませ。", "zh": "歡迎光臨。" },
        { "role": "B", "ja": "{袋|ふくろ}はご{利用|りよう}ですか。", "zh": "需要袋子嗎？" },
        { "role": "A", "ja": "はい、お{願|ねが}いします。{大|おお}きい{袋|ふくろ}でお{願|ねが}いします。", "zh": "要，麻煩給我大袋子。" },
        { "role": "B", "ja": "{袋|ふくろ}は{5円|ごえん}になります。", "zh": "袋子要 5 日圓。" },
        { "role": "A", "ja": "{大丈夫|だいじょうぶ}です。", "zh": "沒關係。" },
        { "role": "B", "ja": "お{弁当|べんとう}は{温|あたた}めますか。", "zh": "便當要加熱嗎？" },
        { "role": "A", "ja": "はい、お{願|ねが}いします。", "zh": "好，麻煩你。" },
        { "role": "B", "ja": "お{箸|はし}はお{付|つ}けしますか。", "zh": "需要筷子嗎？" },
        { "role": "A", "ja": "{二膳|にぜん}お{願|ねが}いします。", "zh": "兩雙，麻煩你。" },
        { "role": "B", "ja": "{合計|ごうけい}{1080円|せんはちじゅうえん}でございます。", "zh": "總計 1,080 日圓。" }
      ]
    },
    {
      "id": "conbini-medicine",
      "title_zh": "藥妝找藥",
      "title_ja": "ドラッグストアで薬を探す",
      "turns": [
        { "role": "A", "ja": "すみません、{頭痛薬|ずつうやく}はどこですか。", "zh": "不好意思，頭痛藥在哪裡？" },
        { "role": "B", "ja": "{2番|にばん}{通路|つうろ}の{右側|みぎがわ}にございます。", "zh": "在 2 號走道的右邊。" },
        { "role": "A", "ja": "{風邪薬|かぜぐすり}もありますか。", "zh": "也有感冒藥嗎？" },
        { "role": "B", "ja": "はい、{同|おな}じ{棚|たな}にあります。", "zh": "有，同一個架上。" },
        { "role": "A", "ja": "{生理用品|せいりようひん}は。", "zh": "生理用品呢？" },
        { "role": "B", "ja": "{奥|おく}の{方|ほう}、{左側|ひだりがわ}です。", "zh": "在裡面，左邊。" },
        { "role": "A", "ja": "ありがとうございます。", "zh": "謝謝。" }
      ]
    },
    {
      "id": "conbini-tax-free",
      "title_zh": "退稅",
      "title_ja": "免税",
      "turns": [
        { "role": "A", "ja": "{免税|めんぜい}でお{願|ねが}いします。", "zh": "請幫我辦免稅。" },
        { "role": "B", "ja": "パスポートをお{願|ねが}いします。", "zh": "請給我護照。" },
        { "role": "A", "ja": "はい、どうぞ。", "zh": "好，請。" },
        { "role": "B", "ja": "{合計|ごうけい}{5500円|ごせんごひゃくえん}、{税抜|ぜいぬ}き{5000円|ごせんえん}です。", "zh": "總計 5,500 日圓，未稅 5,000 日圓。" },
        { "role": "B", "ja": "{袋|ふくろ}は{出国|しゅっこく}まで{開|あ}けないでください。", "zh": "袋子請在出境前不要打開。" },
        { "role": "A", "ja": "はい、{分|わ}かりました。", "zh": "好的，我知道了。" }
      ]
    }
  ],
