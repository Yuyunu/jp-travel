{
  "id": "station",
  "name_zh": "車站",
  "name_ja": "駅",
  "emoji": "🚉",
  "dialogues": [
    {
      "id": "station-shinkansen",
      "title_zh": "買新幹線票",
      "title_ja": "新幹線の切符を買う",
      "turns": [
        {
          "role": "A",
          "ja": "{京|きょう}{都|と}まで{大人|おとな}{二枚|にまい}ください。",
          "zh": "請給我兩張到京都的大人票。"
        },
        {
          "role": "B",
          "ja": "{指|し}{定|てい}{席|せき}か{自|じ}{由|ゆう}{席|せき}か、どちらになさいますか。",
          "zh": "要對號座還是自由座？"
        },
        {
          "role": "A",
          "ja": "{指|し}{定|てい}{席|せき}でお{願|ねが}いします。",
          "zh": "對號座，麻煩你。"
        },
        {
          "role": "B",
          "ja": "{窓|まど}{側|がわ}と{通|つう}{路|ろ}{側|がわ}、どちらがよろしいですか。",
          "zh": "要靠窗還是走道？"
        },
        {
          "role": "A",
          "ja": "{窓|まど}{側|がわ}でお{願|ねが}いします。",
          "zh": "靠窗，麻煩你。"
        },
        {
          "role": "B",
          "ja": "{次|つぎ}の{のぞみ|のぞみ}は10{時|じ}30{分|ぷん}{発|はつ}です。",
          "zh": "下一班 Nozomi 是 10 點 30 分發車。"
        },
        {
          "role": "A",
          "ja": "{何番線|なんばんせん}ですか。",
          "zh": "是第幾月台？"
        },
        {
          "role": "B",
          "ja": "{14番線|じゅうよんばんせん}です。",
          "zh": "14 號月台。"
        }
      ]
    },
    {
      "id": "station-transfer",
      "title_zh": "問轉乘",
      "title_ja": "乗り換えを聞く",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、{渋|しぶ}{谷|や}までどう{行|い}けばいいですか。",
          "zh": "不好意思，到澀谷怎麼走？"
        },
        {
          "role": "B",
          "ja": "{山手|やまのて}{線|せん}に{乗|の}って、{次|つぎ}が{渋|しぶ}{谷|や}です。",
          "zh": "搭山手線，下一站就是澀谷。"
        },
        {
          "role": "A",
          "ja": "{何番線|なんばんせん}ですか。",
          "zh": "幾號月台？"
        },
        {
          "role": "B",
          "ja": "{2番線|にばんせん}です。{改|かい}{札|さつ}を{出|で}て{右|みぎ}です。",
          "zh": "2 號月台，出剪票口右轉。"
        },
        {
          "role": "A",
          "ja": "{所要時間|しょよう じかん}はどれくらいですか。",
          "zh": "大概要多久？"
        },
        {
          "role": "B",
          "ja": "{10分|じゅっぷん}くらいです。",
          "zh": "大概 10 分鐘。"
        },
        {
          "role": "A",
          "ja": "ありがとうございます。",
          "zh": "謝謝。"
        }
      ]
    },
    {
      "id": "station-ic",
      "title_zh": "IC 卡儲值",
      "title_ja": "ICカードのチャージ",
      "turns": [
        {
          "role": "A",
          "ja": "すみません、Suicaにチャージしたいです。",
          "zh": "不好意思，我想幫 Suica 加值。"
        },
        {
          "role": "B",
          "ja": "あちらの{券|けん}{売|ばい}{機|き}でできます。",
          "zh": "在那邊的售票機可以加值。"
        },
        {
          "role": "A",
          "ja": "{現|げん}{金|きん}しか{使|つか}えませんか。",
          "zh": "只能用現金嗎？"
        },
        {
          "role": "B",
          "ja": "はい、{現|げん}{金|きん}のみです。",
          "zh": "對，只能用現金。"
        },
        {
          "role": "A",
          "ja": "{千円|せんえん}{札|さつ}は{使|つか}えますか。",
          "zh": "千元紙鈔可以用嗎？"
        },
        {
          "role": "B",
          "ja": "はい、{使|つか}えます。",
          "zh": "可以用。"
        }
      ]
    }
  ],
