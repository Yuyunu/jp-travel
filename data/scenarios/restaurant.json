    {
      "id": "rest-seating",
      "title_zh": "入店帶位",
      "title_ja": "入店・席案内",
      "turns": [
        { "role": "B", "ja": "いらっしゃいませ。{何名様|なんめいさま}ですか。", "zh": "歡迎光臨，請問幾位？" },
        { "role": "A", "ja": "{二人|ふたり}です。", "zh": "兩個人。" },
        { "role": "B", "ja": "{予約|よやく}はされていますか。", "zh": "請問有訂位嗎？" },
        { "role": "A", "ja": "いいえ、していません。", "zh": "沒有。" },
        { "role": "B", "ja": "{禁煙席|きんえんせき}でよろしいですか。", "zh": "禁菸區可以嗎？" },
        { "role": "A", "ja": "はい、お{願|ねが}いします。", "zh": "好，麻煩你。" },
        { "role": "B", "ja": "こちらへどうぞ。", "zh": "這邊請。" },
        { "role": "A", "ja": "メニューをください。", "zh": "請給我菜單。" }
      ]
    },
    {
      "id": "rest-order",
      "title_zh": "點餐 + 過敏",
      "title_ja": "注文・アレルギー",
      "turns": [
        { "role": "B", "ja": "ご{注文|ちゅうもん}はお{決|き}まりですか。", "zh": "請問決定要點什麼了嗎？" },
        { "role": "A", "ja": "おすすめは{何|なん}ですか。", "zh": "有什麼推薦的？" },
        { "role": "B", "ja": "こちらの{定食|ていしょく}が{人気|にんき}です。", "zh": "這個定食很受歡迎。" },
        { "role": "A", "ja": "じゃあ、これと、これをお{願|ねが}いします。", "zh": "那我要這個，還有這個。" },
        { "role": "B", "ja": "かしこまりました。お{飲|の}み{物|もの}は。", "zh": "好的，飲料呢？" },
        { "role": "A", "ja": "{水|みず}で{結構|けっこう}です。", "zh": "白開水就好。" },
        { "role": "B", "ja": "アレルギーはございますか。", "zh": "請問有過敏的食物嗎？" },
        { "role": "A", "ja": "{卵|たまご}はだめです。{卵抜|たまごぬ}きでお{願|ねが}いします。", "zh": "蛋不行，請去掉蛋。" },
        { "role": "B", "ja": "かしこまりました。{確認|かくにん}いたします。", "zh": "好的，我幫您確認一下。" }
      ]
    },
    {
      "id": "rest-checkout",
      "title_zh": "加點 + 結帳",
      "title_ja": "追加注文・お会計",
      "turns": [
        { "role": "A", "ja": "すみません、ビールをもう{一|ひと}つください。", "zh": "不好意思，再來一杯啤酒。" },
        { "role": "B", "ja": "かしこまりました。", "zh": "好的。" },
        { "role": "A", "ja": "お{会計|かいけい}お{願|ねが}いします。", "zh": "麻煩結帳。" },
        { "role": "B", "ja": "{全部|ぜんぶ}で{三千円|さんぜんえん}です。", "zh": "總共三千日圓。" },
        { "role": "A", "ja": "カードでいいですか。", "zh": "可以刷卡嗎？" },
        { "role": "B", "ja": "はい、こちらにサインをお{願|ねが}いします。", "zh": "可以，請在這邊簽名。" },
        { "role": "A", "ja": "{領収書|りょうしゅうしょ}をお{願|ねが}いします。", "zh": "請給我收據。" },
        { "role": "B", "ja": "{少々|しょうしょう}お{待|ま}ちください。", "zh": "請稍等一下。" },
        { "role": "A", "ja": "ご{馳走様|ちそうさま}でした。", "zh": "謝謝招待（吃飽了）。" }
      ]
    }
  ],
