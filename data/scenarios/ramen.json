{
  "id": "ramen",
  "name_zh": "拉麵店",
  "name_ja": "ラーメン屋",
  "emoji": "🍜",
  "dialogues": [
    {
      "id": "ramen-order",
      "title_zh": "點麵（味／硬度／濃淡）",
      "title_ja": "ラーメンの注文",
      "turns": [
        { "role": "B", "ja": "いらっしゃいませ。ご{注文|ちゅうもん}は。", "zh": "歡迎光臨，請問要點什麼？" },
        { "role": "A", "ja": "{豚骨|とんこつ}ラーメン{一|ひと}つください。", "zh": "請給我一碗豚骨拉麵。" },
        { "role": "B", "ja": "{麺|めん}の{硬|かた}さはいかがしますか。", "zh": "麵的硬度要怎麼樣？" },
        { "role": "A", "ja": "{硬|かた}めでお{願|ねが}いします。", "zh": "硬一點，麻煩你。" },
        { "role": "B", "ja": "{味|あじ}の{濃|こ}さは。", "zh": "口味濃淡呢？" },
        { "role": "A", "ja": "{普通|ふつう}でお{願|ねが}いします。", "zh": "普通就好，麻煩你。" },
        { "role": "B", "ja": "{脂|あぶら}の{量|りょう}は。", "zh": "油的量呢？" },
        { "role": "A", "ja": "{少|すく}なめでお{願|ねが}いします。", "zh": "少一點，麻煩你。" },
        { "role": "B", "ja": "かしこまりました。", "zh": "好的。" }
      ]
    },
    {
      "id": "ramen-topping",
      "title_zh": "加點 + 替玉",
      "title_ja": "トッピング・替玉",
      "turns": [
        { "role": "A", "ja": "すみません、トッピングをお{願|ねが}いします。", "zh": "不好意思，我要加配料。" },
        { "role": "B", "ja": "はい、{何|なに}になさいますか。", "zh": "好的，要點什麼？" },
        { "role": "A", "ja": "{煮卵|にたまご}と{海苔|のり}をお{願|ねが}いします。", "zh": "溏心蛋跟海苔，麻煩你。" },
        { "role": "B", "ja": "かしこまりました。", "zh": "好的。" },
        { "role": "A", "ja": "{替玉|かえだま}もください。", "zh": "也要加麵。" },
        { "role": "B", "ja": "{硬|かた}さはどうしますか。", "zh": "硬度怎麼樣？" },
        { "role": "A", "ja": "バリカタでお{願|ねが}いします。", "zh": "硬麵（バリカタ），麻煩你。" }
      ]
    },
    {
      "id": "ramen-set",
      "title_zh": "套餐 + 結帳",
      "title_ja": "セット・お会計",
      "turns": [
        { "role": "A", "ja": "{餃子|ぎょうざ}セットはありますか。", "zh": "有餃子套餐嗎？" },
        { "role": "B", "ja": "はい、ラーメンに{餃子|ぎょうざ}{五個|ごこ}と{半|はん}ライスがついて{300円|さんびゃくえん}{追加|ついか}です。", "zh": "有，拉麵加 5 顆餃子跟半碗飯，加 300 日圓。" },
        { "role": "A", "ja": "じゃあ、それでお{願|ねが}いします。", "zh": "那就來這個，麻煩你。" },
        { "role": "A", "ja": "お{会計|かいけい}お{願|ねが}いします。", "zh": "麻煩結帳。" },
        { "role": "B", "ja": "{食券|しょっけん}は{先|さき}に{券売機|けんばいき}でお{買|か}い{求|もと}めください。", "zh": "餐券請先在售票機買。" },
        { "role": "A", "ja": "あ、すみません、{知|し}りませんでした。", "zh": "啊，不好意思，我不知道。" }
      ]
    }
  ],
